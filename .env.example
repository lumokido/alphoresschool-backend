# Copy to .env and adjust values for local development.
# Do not commit .env — it is listed in .gitignore.

# PostgreSQL
POSTGRES_DB=lumo
POSTGRES_USER=lumo
POSTGRES_PASSWORD=lumo
POSTGRES_PORT=5432

# Spring Boot
APP_PORT=8080
SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/lumo
SPRING_DATASOURCE_USERNAME=lumo
SPRING_DATASOURCE_PASSWORD=lumo

# JWT secrets (generate strong random values for production / DigitalOcean)
APP_JWT_SECRET=changeme-dev-only-replace-in-production
APP_JWT_TEACHER_SECRET=changeme-teacher-dev-only
APP_JWT_STUDENT_SECRET=changeme-student-dev-only
